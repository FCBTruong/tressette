; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Tressette Royal"
run/main_scene="res://scenes/InitScene.tscn"
config/features=PackedStringArray("4.3", "Mobile")
boot_splash/bg_color=Color(0.984314, 0.772549, 0.643137, 1)
boot_splash/image="res://splash_screen.png"
config/icon="res://icon.png"

[autoload]

StorageCache="*res://scripts/storage_cache.gd"
Config="*res://scripts/config.gd"
GameConstants="*res://scripts/game_constants.gd"
SceneManager="*res://scripts/scene_manager.gd"
PlayerInfoMgr="*res://scripts/player_info_mgr.gd"
WebsocketClient="*res://scripts/network/websocket_client.gd"
GameClient="*res://scripts/network/game_client.gd"
ProtocolUtils="*res://scripts/network/protocol_utils.gd"
GameManager="*res://scripts/game_manager.gd"
SignalBus="*res://scripts/signal_bus.gd"
InGameChatMgr="*res://scripts/game/chat/ingame_chat_mgr.gd"
StringUtils="*res://scripts/utils/string_utils.gd"
PaymentMgr="*res://scripts/modules/payment/payment_mgr.gd"
FriendManager="*res://scripts/modules/friend/friend_manager.gd"
LoginMgr="*res://scripts/login_mgr.gd"
SoundManager="*res://scripts/sound_manager.gd"
FirebaseMgr="*res://scripts/base/firebase_mgr.gd"
LogsMgr="*res://scripts/logs_mgr.gd"
GameServerConfig="*res://scripts/game_server_config.gd"
EffectMgr="*res://scripts/effect_mgr.gd"
NodeUtils="*res://scripts/utils/node_utils.gd"
AppVersion="*res://scripts/base/app_version.gd"
NativeMgr="*res://scripts/base/native_mgr.gd"

[display]

window/size/viewport_width=1200
window/size/viewport_height=600
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[editor_plugins]

enabled=PackedStringArray("res://addons/custom_native/plugin.cfg", "res://addons/firebase_plugin/plugin.cfg", "res://addons/protobuf/plugin.cfg")

[internationalization]

locale/translations=PackedStringArray("res://localization/localize.csv", "res://localization/localize.en.translation", "res://localization/localize.it.translation", "res://localization/localize.vi.translation")

[rendering]

renderer/rendering_method="mobile"
textures/vram_compression/import_etc2_astc=true
